#!/usr/bin/env bash
# Installs nginx and configures it to serve a page containing Holberton School

# Update package list and install nginx quietly
apt-get update -y > /dev/null 2>&1
apt-get install -y nginx > /dev/null 2>&1

# Create the required HTML page in the default web root
echo "Holberton School for the win!" > /var/www/html/index.html

# Start/restart nginx using service command (systemctl not allowed)
service nginx restart > /dev/null 2>&1
